# Variables partagées entre services pour le développement local (docker-compose).
# backend-api/ possède son propre .env (généré par Laravel) qui doit reprendre
# les mêmes identifiants de base de données que ci-dessous.

POSTGRES_DB=siarn
POSTGRES_USER=siarn
POSTGRES_PASSWORD=siarn
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

OCR_DATABASE_URL=postgresql://siarn:siarn@postgres:5432/siarn
OCR_TESSDATA_DIR=/models/tessdata
OCR_MODELE_OCR_VERSION=siarn-ocr-dev
OCR_SEUIL_CONFIANCE_CHAMP=0.85

VITE_API_BASE_URL=http://localhost:8000
